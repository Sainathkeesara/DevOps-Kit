# ansible/inventory.ini.example
# Copy to inventory.ini and fill in your SSH key path and host IPs

[all:vars]
ansible_user=ubuntu
ansible_ssh_private_key_file=~/.ssh/k8s-provisioning-key
ansible_python_interpreter=/usr/bin/python3
ansible_ssh_common_args='-o StrictHostKeyChecking=no -o ProxyJump=ubuntu@<BASTION_PUBLIC_IP>'

[kube_control_plane]
# Format: <short-name> ansible_host=<private-ip>
prod-cp-1 ansible_host=10.0.1.10
prod-cp-2 ansible_host=10.0.1.11
prod-cp-3 ansible_host=10.0.1.12

[kube_workers]
# Format: <short-name> ansible_host=<private-ip>
prod-worker-1 ansible_host=10.0.1.20
prod-worker-2 ansible_host=10.0.1.21
prod-worker-3 ansible_host=10.0.1.22
